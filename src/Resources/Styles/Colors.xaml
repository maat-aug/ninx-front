<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Paleta Principal Ninx ERP -->
    <Color x:Key="Primary">#1A9E9A</Color>
    <Color x:Key="PrimaryDark">#127A77</Color>
    <Color x:Key="PrimaryLight">#4DD9D0</Color>

    <Color x:Key="BgDark">#0A1628</Color>
    <Color x:Key="BgPanel">#0F1E30</Color>
    <Color x:Key="BgCard">#162438</Color>

    <Color x:Key="TextPrimary">#F0F4F8</Color>
    <Color x:Key="TextSecondary">#8BA3BC</Color>
    <Color x:Key="TextMuted">#4A6580</Color>

    <Color x:Key="Error">#E05A6A</Color>
    <Color x:Key="Success">#3EC97A</Color>
    <Color x:Key="Warning">#F5A623</Color>

</ResourceDictionary>
