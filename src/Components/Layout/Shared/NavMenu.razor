@using NinxERP.Domain.Entities
@using NinxERP.Domain.Interfaces
@inject UserSession Session
@inject IAuthService AuthService
@inject NavigationManager Navigation

<nav class="top-nav">
    <div class="brand-section" @onclick='() => Navigation.NavigateTo("/mainpage")' style="cursor:pointer">
        <img src="images/nina_logo_clean.png" alt="Nina" class="brand-logo-small" />
        <div class="brand-info">
            <span class="brand-name-dash">Ninx</span>
        </div>
    </div>
    
    <div class="user-controls">
        <div class="welcome-stack">
            <span class="welcome-text">Olá, <strong>@Session.CurrentUser?.Name</strong></span>
            <span class="commerce-name user-commerce-name">@Session.CurrentCommerceName</span>
        </div>
        <button class="menu-trigger" @onclick="ToggleMenu" aria-label="Abrir menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>
</nav>

@if (isMenuOpen)
{
    <div class="menu-overlay" @onclick="ToggleMenu">
        <div class="side-menu" @onclick:stopPropagation>
            <header class="menu-header">
                <h3>Menu de Ações</h3>
                <button class="close-btn" @onclick="ToggleMenu" aria-label="Fechar menu">✕</button>
            </header>
            <div class="menu-items">
                <button class="menu-item" @onclick="OpenCommerceModal">
                    <div class="item-icon">🏪</div>
                    <div class="item-text">
                        <span>Trocar Comércio</span>
                        <small>Selecionar outra unidade</small>
                    </div>
                </button>

                <button class="menu-item logout-item" @onclick="Logout">
                    <div class="item-icon">👤</div>
                    <div class="item-text">
                        <span>Trocar Usuário</span>
                        <small>Sair desta conta</small>
                    </div>
                </button>

                @if (Session.IsAdmin)
                {
                    <div class="menu-divider"></div>
                    <button class="menu-item admin-item" @onclick='() => NavigateTo("feature/admin")'>
                        <div class="item-icon">🛡️</div>
                        <div class="item-text">
                            <span>Painel Admin</span>
                            <small>Gestão do sistema</small>
                        </div>
                    </button>
                }
            </div>
        </div>
    </div>
}

@if (isCommerceModalOpen)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <header class="modal-header">
                <h2>Selecionar Unidade</h2>
            </header>
            <div class="commerce-list">
                @if (isLoadingComercios)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary"></div>
                    </div>
                }
                else
                {
                    @foreach (var commerce in comerciosDisponiveis)
                    {
                        <button class="commerce-option @(Session.CurrentCommerceId == commerce.Id ? "active" : "")" 
                                @onclick="() => SelectCommerce(commerce.Id)">
                            <span class="opt-name">@commerce.Name</span>
                            @if (Session.CurrentCommerceId == commerce.Id)
                            {
                                <span class="opt-badge">Atual</span>
                            }
                        </button>
                    }
                }
            </div>
            <footer class="modal-footer">
                <button class="btn-cancel" @onclick="CloseCommerceModal">Cancelar</button>
            </footer>
        </div>
    </div>
}

@code {
    private bool isMenuOpen;
    private bool isCommerceModalOpen;
    private bool isLoadingComercios;
    private List<Commerce> comerciosDisponiveis = new();

    private void ToggleMenu() => isMenuOpen = !isMenuOpen;
    
    private async Task OpenCommerceModal()
    {
        isMenuOpen = false;
        isCommerceModalOpen = true;
        isLoadingComercios = true;
        
        if (Session.CurrentUser != null)
        {
            comerciosDisponiveis = await AuthService.GetComerciosUsuarioAsync(Session.CurrentUser.Id);
        }
        
        isLoadingComercios = false;
    }

    private void CloseCommerceModal() => isCommerceModalOpen = false;

    private async Task SelectCommerce(string id)
    {
        if (Session.CurrentCommerceId == id)
        {
            CloseCommerceModal();
            return;
        }

        var sucesso = await AuthService.TrocarComercioAsync(int.Parse(id));
        if (sucesso)
        {
            CloseCommerceModal();
            Navigation.NavigateTo("/mainpage", true);
        }
    }

    private void NavigateTo(string route)
    {
        isMenuOpen = false;
        Navigation.NavigateTo($"/mainpage/{route}");
    }

    private void Logout()
    {
        Session.End();
        Navigation.NavigateTo("/login", true);
    }
}
