@page "/mainpage/produtosestoque"
@using NinxERP.Domain.DTOs
@using NinxERP.Domain.Interfaces
@using NinxERP.Domain.Entities
@inject IEstoqueService EstoqueService
@inject IProdutoService ProdutoService
@inject UserSession Session
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Estoque — Ninx</PageTitle>

<div class="estoque-container">
    @if (!Session.IsAuthenticated)
    {
        <div class="auth-guard">
            <p>Acesso negado. Redirecionando...</p>
        </div>
    }
    else
    {
        @* ── CABEÇALHO ── *@
        @* ── CABEÇALHO COM FILTRO RETRÁTIL SLIM ── *@
        <div class="estoque-header">
            <div class="header-left">
                <h2><i class="bi bi-boxes"></i> Estoque & Produtos</h2>
                <span class="header-subtitle">Gerencie produtos e quantidades em estoque</span>
            </div>

            <div class="header-actions-container">
                <div class="header-actions">
                    @* Botão de Filtro à esquerda da busca *@
                    <button class="btn-filtro-toggle @(exibirPainelFiltros ? "ativo" : "")"
                            @onclick="TogglePainelFiltros"
                            title="Filtrar por Status">
                        <i class="bi bi-funnel"></i>
                    </button>

                    <div class="search-bar">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               value="@termoBusca"
                               @oninput="async e => { termoBusca = e.Value?.ToString() ?? string.Empty; await FiltrarProdutos(); }"
                               placeholder="Buscar por nome ou código de barras..." />
                        @if (!string.IsNullOrEmpty(termoBusca))
                        {
                            <button class="btn-clear-search" @onclick="LimparBusca"><i class="bi bi-x"></i></button>
                        }
                    </div>

                    <button class="btn-novo-produto" @onclick="AbrirModalNovoProduto">
                        <i class="bi bi-plus-lg"></i> Novo Produto
                    </button>
                </div>

                @* Mini Painel de Filtros Ultrafino *@
                @if (exibirPainelFiltros)
                {
                    <div class="dropdown-overlay" @onclick="() => exibirPainelFiltros = false"></div>

                    <div class="painel-filtros-dropdown">
                        <span class="filtros-label">Status:</span>
                        <div class="filtros-pills-grupo">
                            <label class="filtro-pill status-ok @(exibirNormal ? "selecionado" : "")">
                                <input type="checkbox" checked="@exibirNormal" @onchange="async e => { exibirNormal = (bool)e.Value!; await OnCheckboxChanged(); }" style="display:none;" />
                                <span class="indicador-cor"></span> Normal
                            </label>

                            <label class="filtro-pill status-baixo @(exibirBaixoMinimo ? "selecionado" : "")">
                                <input type="checkbox" checked="@exibirBaixoMinimo" @onchange="async e => { exibirBaixoMinimo = (bool)e.Value!; await OnCheckboxChanged(); }" style="display:none;" />
                                <span class="indicador-cor"></span> Abaixo do Mínimo
                            </label>

                            <label class="filtro-pill status-zerado @(exibirSemEstoque ? "selecionado" : "")">
                                <input type="checkbox" checked="@exibirSemEstoque" @onchange="async e => { exibirSemEstoque = (bool)e.Value!; await OnCheckboxChanged(); }" style="display:none;" />
                                <span class="indicador-cor"></span> Sem Estoque
                            </label>

                            <label class="filtro-pill status-inativo @(exibirDesativados ? "selecionado" : "")">
                                <input type="checkbox" checked="@exibirDesativados" @onchange="async e => { exibirDesativados = (bool)e.Value!; await OnCheckboxChanged(); }" style="display:none;" />
                                <span class="indicador-cor"></span> Desativados
                            </label>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ── ALERTAS ── *@
        @if (!string.IsNullOrEmpty(mensagemSucesso))
        {
            <div class="alert-estoque success animate-fade-in">
                <i class="bi bi-check-circle-fill"></i> @mensagemSucesso
            </div>
        }
        @if (!string.IsNullOrEmpty(mensagemErro))
        {
            <div class="alert-estoque error animate-fade-in">
                <i class="bi bi-exclamation-triangle-fill"></i> @mensagemErro
            </div>
        }

        @* ── CARDS DE RESUMO (Apenas produtos ATIVOS contam aqui) ── *@
        @* ── CARDS DE RESUMO DE ESTOQUE GLOBAL ── *@
        <div class="resumo-cards">
            <div class="resumo-card">
                <div class="resumo-icon blue"><i class="bi bi-box-seam"></i></div>
                <div class="resumo-info">
                    @* Exibe o total global mapeado da API *@
                    <span class="resumo-valor">@totalAtivos</span>
                    <span class="resumo-label">Produtos Ativos</span>
                </div>
            </div>
            <div class="resumo-card">
                <div class="resumo-icon green"><i class="bi bi-check2-circle"></i></div>
                <div class="resumo-info">
                    @* Exibe o total global mapeado da API *@
                    <span class="resumo-valor">@totalNormal</span>
                    <span class="resumo-label">Estoque Normal</span>
                </div>
            </div>
            <div class="resumo-card">
                <div class="resumo-icon yellow"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="resumo-info">
                    @* Exibe o total global mapeado da API *@
                    <span class="resumo-valor">@totalBaixo</span>
                    <span class="resumo-label">Abaixo do Mínimo</span>
                </div>
            </div>
            <div class="resumo-card">
                <div class="resumo-icon red"><i class="bi bi-slash-circle"></i></div>
                <div class="resumo-info">
                    @* Exibe o total global mapeado da API *@
                    <span class="resumo-valor">@totalZerado</span>
                    <span class="resumo-label">Sem Estoque</span>
                </div>
            </div>
        </div>

        @* ── TABELA PRINCIPAL ── *@
        <div class="estoque-card">
            @if (isCarregando)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" style="width:2.5rem;height:2.5rem;"></div>
                    <p>Carregando produtos...</p>
                </div>
            }
            else if (produtosFiltrados.Count == 0)
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h4>Nenhum produto encontrado</h4>
                    <p>@(string.IsNullOrEmpty(termoBusca) ? "Adicione o primeiro produto clicando em \"Novo Produto\"." : "Tente outro termo de busca.")</p>
                </div>
            }
            else
            {
                <div class="table-wrapper">
                    <table class="tabela-estoque">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th>Código</th>
                                <th class="text-center">Qtd. Estoque</th>
                                <th class="text-center">Qtd. Mínima</th>
                                <th class="text-end">Preço Venda</th>
                                <th class="text-end">Preço Custo</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var produto in produtosFiltrados)
                            {
                                var status = ObterStatus(produto);
                                <tr class="@(produto.Ativo ? "" : "row-inativo")">
                                    <td>
                                        <div class="produto-nome">@produto.Nome</div>
                                        <small class="produto-meta">@produto.UnidadeMedida · @produto.CategoriaNome</small>
                                    </td>
                                    <td>
                                        <span class="codigo-barras-pill">@(string.IsNullOrEmpty(produto.CodigoBarras) ? "—" : produto.CodigoBarras)</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="qty-badge @status.Classe">@((int)produto.Quantidade)</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="qty-minima">@((int)produto.QuantidadeMinima)</span>
                                    </td>
                                    <td class="text-end fw-bold">R$ @produto.PrecoVenda.ToString()</td>
                                    <td class="text-end text-muted-soft">R$ @(produto.PrecoCusto?.ToString() ?? "0,00")</td>
                                    <td class="text-center">
                                        <span class="status-pill @status.Classe">@status.Texto</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="acoes-grupo">
                                            @if (produto.Ativo)
                                            {
                                                <button class="btn-acao edit" title="Editar produto" @onclick="() => AbrirModalEdicao(produto)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn-acao delete" title="Excluir produto" @onclick="() => ConfirmarExclusao(produto)">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn-acao activate" title="Ativar produto" @onclick="() => AlternarStatusProduto(produto, true)">
                                                    <i class="bi bi-power"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @* ── CONTROLES DE PAGINAÇÃO ── *@
        @if (totalPaginas > 1)
        {
            <div class="paginacao-container">
                <div class="paginacao-info">
                    Exibindo página <strong>@paginaAtual</strong> de <strong>@totalPaginas</strong> (Total de @totalItens produtos)
                </div>
                <div class="paginacao-botoes">
                    <button class="btn-paginacao" @onclick="() => MudarPagina(paginaAtual - 1)" disabled="@(paginaAtual == 1)">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </button>

                    @for (int i = 1; i <= totalPaginas; i++)
                    {
                        var paginaNumero = i;
                        <button class="btn-paginacao-numero @(paginaNumero == paginaAtual ? "ativo" : "")"
                                @onclick="() => MudarPagina(paginaNumero)">
                            @paginaNumero
                        </button>
                    }

                    <button class="btn-paginacao" @onclick="() => MudarPagina(paginaAtual + 1)" disabled="@(paginaAtual == totalPaginas)">
                        Próxima <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }

        @* ══════════════════════════════════════════════
           MODAL — NOVO / EDITAR PRODUTO
           ══════════════════════════════════════════════ *@
        @if (modalProdutoAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalProduto">
                <div class="modal-card" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h4><i class="bi @(editandoProduto ? "bi-pencil-square" : "bi-plus-circle")"></i> @(editandoProduto ? "Editar Produto" : "Novo Produto")</h4>
                        <button class="btn-fechar-modal" @onclick="FecharModalProduto"><i class="bi bi-x-lg"></i></button>
                    </div>

                    <div class="modal-body">
                        <div class="form-grid">
                            <div class="form-group span-2">
                                <label>Nome do Produto</label>
                                <input type="text" @bind="formProduto.Nome" placeholder="Ex: Arroz Integral 1kg" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label>Código de Barras</label>
                                <input type="text" @bind="formProduto.CodigoBarras" placeholder="Ex: 7891234567890" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label>Unidade de Medida</label>
                                <input type="text" @bind="formProduto.UnidadeMedida" placeholder="Ex: UN, KG, L" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label>Preço de Venda (R$)</label>
                                <input type="number" step="0.01" @bind="formProduto.PrecoVenda" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label>Preço de Custo (R$)</label>
                                <input type="number" step="0.01" @bind="formProduto.PrecoCusto" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label>Validade</label>
                                <input type="date" @bind="formProduto.Validade" class="form-input" />
                            </div>

                            @* Quantidade Mínima visível tanto na criação quanto na edição *@
                            <div class="form-group">
                                <label>Quantidade Mínima</label>
                                <input type="number" @bind="formProduto.QuantidadeMinima" min="0" class="form-input" />
                            </div>

                            @if (!editandoProduto)
                            {
                                <div class="form-group">
                                    <label>Estoque Inicial</label>
                                    <input type="number" @bind="formProduto.EstoqueInicial" min="0" class="form-input" />
                                </div>
                            }
                            else
                            {
                                @* Edição direta da quantidade atual de estoque ativada no fluxo do lápis *@
                                <div class="form-group">
                                    <label>Quantidade em Estoque</label>
                                    <input type="number" @bind="formProduto.Quantidade" min="0" class="form-input" />
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert-estoque error mt-3">
                                <i class="bi bi-exclamation-triangle-fill"></i> @mensagemErroModal
                            </div>
                        }
                    </div>

                    <div class="modal-footer">
                        <button class="btn-action secondary" @onclick="FecharModalProduto">Cancelar</button>
                        <button class="btn-action primary" @onclick="SalvarProduto" disabled="@isSalvando">
                            @if (isSalvando)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            @(editandoProduto ? "Salvar Alterações" : "Criar Produto")
                        </button>
                    </div>
                </div>
            </div>
        }

        @* ── MODAL — AJUSTAR ESTOQUE INDEPENDENTE ── *@
        @if (modalEstoqueAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalEstoque">
                <div class="modal-card modal-card-sm" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h4><i class="bi bi-clipboard2-plus"></i> Ajustar Estoque</h4>
                        <button class="btn-fechar-modal" @onclick="FecharModalEstoque"><i class="bi bi-x-lg"></i></button>
                    </div>

                    <div class="modal-body">
                        <div class="produto-destaque-modal">
                            <i class="bi bi-box-seam"></i>
                            <div>
                                <strong>@produtoSelecionado?.Nome</strong>
                                <small>@produtoSelecionado?.UnidadeMedida</small>
                            </div>
                        </div>

                        <div class="form-grid mt-4">
                            <div class="form-group">
                                <label>Quantidade em Estoque</label>
                                <input type="number" @bind="formEstoque.Quantidade" min="0" class="form-input form-input-lg" />
                            </div>
                            <div class="form-group">
                                <label>Quantidade Mínima</label>
                                <input type="number" @bind="formEstoque.QuantidadeMinima" min="0" class="form-input form-input-lg" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(mensagemErroModal))
                        {
                            <div class="alert-estoque error mt-3">
                                <i class="bi bi-exclamation-triangle-fill"></i> @mensagemErroModal
                            </div>
                        }
                    </div>

                    <div class="modal-footer">
                        <button class="btn-action secondary" @onclick="FecharModalEstoque">Cancelar</button>
                        <button class="btn-action success" @onclick="SalvarEstoque" disabled="@isSalvando">
                            @if (isSalvando)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Confirmar
                        </button>
                    </div>
                </div>
            </div>
        }

        @* ── MODAL — CONFIRMAR EXCLUSÃO ── *@
        @if (modalExclusaoAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalExclusao">
                <div class="modal-card modal-card-sm" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h4><i class="bi bi-trash3 text-danger"></i> Excluir Produto</h4>
                        <button class="btn-fechar-modal" @onclick="FecharModalExclusao"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="modal-body text-center" style="padding: 32px 24px;">
                        <div class="delete-icon-wrapper">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <p class="delete-confirm-text">Tem certeza que deseja excluir <strong>@produtoSelecionado?.Nome</strong>?</p>
                        <p class="delete-confirm-sub">Esta ação não pode ser desfeita.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-action secondary" @onclick="FecharModalExclusao">Cancelar</button>
                        <button class="btn-action danger" @onclick="ExcluirProduto" disabled="@isSalvando">
                            @if (isSalvando)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Excluir
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .estoque-container {
        padding: 24px;
        max-width: 1400px;
        margin: 0 auto;
        color: #fff;
        font-family: 'Inter', sans-serif;
        min-height: 90vh;
    }

    .estoque-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .header-left h2 {
        margin: 0;
        font-size: 1.8rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .header-left h2 i {
            color: #007bff;
        }

    .header-subtitle {
        color: rgba(255,255,255,0.45);
        font-size: 0.9rem;
        margin-top: 4px;
        display: block;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .search-bar {
        display: flex;
        align-items: center;
        background: rgba(0,0,0,0.35);
        border: 1.5px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 10px 18px;
        gap: 10px;
        min-width: 280px;
        transition: 0.25s;
    }

        .search-bar:focus-within {
            border-color: #007bff;
            background: rgba(0,0,0,0.5);
            box-shadow: 0 0 20px rgba(0,123,255,0.15);
        }

        .search-bar i {
            color: rgba(255,255,255,0.35);
            font-size: 1rem;
            flex-shrink: 0;
        }

        .search-bar input {
            background: transparent;
            border: none;
            color: #fff;
            font-size: 0.95rem;
            outline: none;
            width: 100%;
        }

    .btn-clear-search {
        background: none;
        border: none;
        color: rgba(255,255,255,0.35);
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        transition: 0.2s;
    }

        .btn-clear-search:hover {
            color: #fff;
        }

    .btn-novo-produto {
        background: #007bff;
        border: none;
        color: #fff;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s;
        white-space: nowrap;
    }

        .btn-novo-produto:hover {
            background: #0056b3;
            box-shadow: 0 8px 25px rgba(0,123,255,0.3);
            transform: translateY(-1px);
        }

    .alert-estoque {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 20px;
        border-radius: 12px;
        font-weight: 500;
        font-size: 0.95rem;
        margin-bottom: 20px;
        animation: fadeIn 0.3s ease;
    }

        .alert-estoque.success {
            background: rgba(40,167,69,0.12);
            border: 1px solid rgba(40,167,69,0.3);
            color: #5dd879;
        }

        .alert-estoque.error {
            background: rgba(220,53,69,0.12);
            border: 1px solid rgba(220,53,69,0.3);
            color: #ff6b7d;
        }

        .alert-estoque i {
            font-size: 1.1rem;
            flex-shrink: 0;
        }

    .mt-3 {
        margin-top: 12px;
    }

    .resumo-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .resumo-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: 0.2s;
    }

        .resumo-card:hover {
            background: rgba(255,255,255,0.07);
            transform: translateY(-2px);
        }

    .resumo-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

        .resumo-icon.blue {
            background: rgba(0,123,255,0.15);
            color: #007bff;
        }

        .resumo-icon.green {
            background: rgba(40,167,69,0.15);
            color: #28a745;
        }

        .resumo-icon.yellow {
            background: rgba(255,193,7,0.15);
            color: #ffc107;
        }

        .resumo-icon.red {
            background: rgba(220,53,69,0.15);
            color: #dc3545;
        }

    .resumo-info {
        display: flex;
        flex-direction: column;
    }

    .resumo-valor {
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1;
    }

    .resumo-label {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.45);
        margin-top: 4px;
        font-weight: 500;
    }

    .estoque-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        overflow: hidden;
    }

    .loading-state, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        gap: 16px;
        color: rgba(255,255,255,0.4);
    }

        .empty-state i {
            font-size: 3.5rem;
        }

        .empty-state h4 {
            color: #fff;
            margin: 0;
            font-weight: 700;
        }

        .empty-state p {
            margin: 0;
            font-size: 1rem;
            text-align: center;
        }

    .table-wrapper {
        overflow-x: auto;
        max-height: 480px; 
        overflow-y: auto; 
    }

        .table-wrapper::-webkit-scrollbar {
            width: 6px;
