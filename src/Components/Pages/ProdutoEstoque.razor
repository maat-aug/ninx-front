            }
        }
        catch (Exception ex)
        {
            mensagemErro = "Erro ao carregar os produtos.";
            produtosFiltrados = new List<ProdutoDTO>();
        }
        finally
        {
            isCarregando = false;
            StateHasChanged();
        }
    }

    private async Task OnCheckboxChanged()
    {
        paginaAtual = 1; 
        await CarregarDados();
    }

    private async Task MudarPagina(int novaPagina)
    {
        if (novaPagina >= 1 && novaPagina <= totalPaginas && novaPagina != paginaAtual)
        {
            paginaAtual = novaPagina;
            await CarregarDados();
        }
    }

    private async Task AlterarFiltro(string novoFiltro)
    {
        filtroSelecionado = novoFiltro;
        paginaAtual = 1; 
        await CarregarDados(); 
    }

    private async Task FiltrarProdutos()
    {
        paginaAtual = 1; 
        await CarregarDados();
    }

    private async Task LimparBusca()
    {
        termoBusca = string.Empty;
        paginaAtual = 1;
        await CarregarDados();
    }

    private (string Classe, string Texto) ObterStatus(ProdutoDTO p)
    {
        if (!p.Ativo) return ("inativo", "Desativado"); 
        if (p.Quantidade == 0) return ("zerado", "Sem Estoque");
        if (p.Quantidade < p.QuantidadeMinima) return ("baixo", "Abaixo do Mín.");
        return ("ok", "Normal");
    }

    private async Task ExibirSucesso(string msg)
    {
        mensagemSucesso = msg;
        StateHasChanged();
        await Task.Delay(3500);
        mensagemSucesso = string.Empty;
        StateHasChanged();
    }

    // ════════════════════════════════════════════
    // MODAL — PRODUTO (NOVO / EDITAR)
    // ════════════════════════════════════════════

    private void AbrirModalNovoProduto()
    {
        editandoProduto = false;
        produtoSelecionado = null;
        formProduto = new FormProduto();
        mensagemErroModal = string.Empty;
        modalProdutoAberto = true;
    }

    private void AbrirModalEdicao(ProdutoDTO produto)
    {
        editandoProduto = true;
        produtoSelecionado = produto;

        // Alimenta o formulário com dados cadastrais + dados de estoque para a edição unificada
        formProduto = new FormProduto
        {
            Nome = produto.Nome,
            CodigoBarras = produto.CodigoBarras,
            UnidadeMedida = produto.UnidadeMedida,
            PrecoVenda = produto.PrecoVenda,
            PrecoCusto = produto.PrecoCusto,
            Validade = produto.Validade,
            QuantidadeMinima = (int)produto.QuantidadeMinima,
            Quantidade = (int)produto.Quantidade,
            EstoqueInicial = 0
        };
        mensagemErroModal = string.Empty;
        modalProdutoAberto = true;
    }

    private async Task AlternarStatusProduto(ProdutoDTO produto, bool ativar)
    {
        isCarregando = true; 
        mensagemErro = string.Empty;
        StateHasChanged();

        try
        {

            await ProdutoService.UpdateAsync(produto.ProdutoID, new AtualizarProdutoDTO
            {
                Nome = produto.Nome,
                CodigoBarras = produto.CodigoBarras,
                UnidadeMedida = produto.UnidadeMedida,
                PrecoVenda = produto.PrecoVenda,
                PrecoCusto = produto.PrecoCusto,
                Validade = produto.Validade,
                Ativo = true
            });

            await CarregarDados();
            string acaoTexto = ativar ? "ativado" : "desativado";
            await ExibirSucesso($"Produto \"{produto.Nome}\" {acaoTexto} com sucesso.");
        }
        catch (Exception ex)
        {
            mensagemErro = "Erro ao alterar o status do produto. Tente novamente.";
        }
        finally
        {
            isCarregando = false;
            StateHasChanged();
        }
    }

    private void FecharModalProduto()
    {
        modalProdutoAberto = false;
        mensagemErroModal = string.Empty;
    }

    private async Task SalvarProduto()
    {
        mensagemErroModal = string.Empty;
        if (string.IsNullOrWhiteSpace(formProduto.Nome))
        {
            mensagemErroModal = "O nome do produto é obrigatório.";
            return;
        }

        isSalvando = true;
        try
        {
            if (editandoProduto && produtoSelecionado != null)
            {
                // 1. Atualiza dados principais do Produto
                await ProdutoService.UpdateAsync(produtoSelecionado.ProdutoID, new AtualizarProdutoDTO
                {
                    Nome = formProduto.Nome,
                    CodigoBarras = formProduto.CodigoBarras,
                    UnidadeMedida = formProduto.UnidadeMedida,
                    PrecoVenda = formProduto.PrecoVenda,
                    PrecoCusto = formProduto.PrecoCusto,
                    Validade = formProduto.Validade
                });

                // 2. Atualiza dados de Estoque (IEstoqueService entra em ação apenas para salvar a alteração)
                var estoqueDto = new AtualizarEstoqueDTO
                {
                    ProdutoID = produtoSelecionado.ProdutoID,
                    Quantidade = formProduto.Quantidade,
                    QuantidadeMinima = formProduto.QuantidadeMinima
                };

                if (produtoSelecionado.EstoqueID > 0)
                    await EstoqueService.UpdateAsync(produtoSelecionado.EstoqueID, estoqueDto);
                else
                    await EstoqueService.CreateAsync(estoqueDto);

                FecharModalProduto();
                await CarregarDados();
                await ExibirSucesso($"Produto e estoque de \"{formProduto.Nome}\" atualizados com sucesso.");
            }
            else
            {
                await ProdutoService.CreateAsync(new CriarProdutoDTO
                {
                    Nome = formProduto.Nome,
                    ComercioID = (Convert.ToInt32(Session.CurrentCommerceId)),
                    CodigoBarras = formProduto.CodigoBarras,
                    UnidadeMedida = formProduto.UnidadeMedida,
                    PrecoVenda = formProduto.PrecoVenda,
                    PrecoCusto = formProduto.PrecoCusto,
                    Validade = formProduto.Validade,
                    EstoqueInicial = formProduto.EstoqueInicial,
                    QuantidadeMinima = formProduto.QuantidadeMinima
                });

                FecharModalProduto();
                await CarregarDados();
                await ExibirSucesso($"Produto \"{formProduto.Nome}\" criado com sucesso.");
            }
        }
        catch (Exception)
        {
            mensagemErroModal = "Erro ao salvar produto. Tente novamente.";
        }
        finally
        {
            isSalvando = false;
        }
    }

    private void FecharModalEstoque()
    {
        modalEstoqueAberto = false;
        mensagemErroModal = string.Empty;
    }

    private async Task SalvarEstoque()
    {
        if (produtoSelecionado == null) return;
        isSalvando = true;
        mensagemErroModal = string.Empty;
        try
        {
            var dto = new AtualizarEstoqueDTO
            {
                ProdutoID = produtoSelecionado.ProdutoID,
                Quantidade = formEstoque.Quantidade,
                QuantidadeMinima = formEstoque.QuantidadeMinima
            };

            if (produtoSelecionado.EstoqueID > 0)
                await EstoqueService.UpdateAsync(produtoSelecionado.EstoqueID, dto);
            else
                await EstoqueService.CreateAsync(dto);

            FecharModalEstoque();
            await CarregarDados();
            await ExibirSucesso($"Estoque de \"{produtoSelecionado.Nome}\" atualizado.");
        }
        catch
        {
            mensagemErroModal = "Erro ao atualizar estoque. Tente novamente.";
        }
        finally
        {
            isSalvando = false;
        }
    }

    // ════════════════════════════════════════════
    // MODAL — EXCLUSÃO
    // ════════════════════════════════════════════

    private void ConfirmarExclusao(ProdutoDTO produto)
    {
        produtoSelecionado = produto;
        modalExclusaoAberto = true;
    }

    private void FecharModalExclusao() => modalExclusaoAberto = false;

    private async Task ExcluirProduto()
    {
        if (produtoSelecionado == null) return;
        isSalvando = true;
        try
        {
            await ProdutoService.DeleteAsync(produtoSelecionado.ProdutoID);
            var nome = produtoSelecionado.Nome;
            FecharModalExclusao();
            await CarregarDados();
            await ExibirSucesso($"Produto \"{nome}\" excluído.");
        }
        catch
        {
            mensagemErro = "Erro ao excluir produto. Tente novamente.";
            FecharModalExclusao();
        }
        finally
        {
            isSalvando = false;
        }
    }

