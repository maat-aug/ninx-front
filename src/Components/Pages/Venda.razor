@code {
    private ElementReference inputBuscaProduto;
    private ElementReference inputValorDinheiro;
    private ElementReference inputValorFiado;

    private int etapaAtual = 1;
    private List<ItemVendaDTO> carrinho = new();
    private decimal totalVenda;
    private decimal totalVendaConcluida;
    private string codigoBarrasInput = string.Empty;
    private string mensagemErro = string.Empty;
    private string mensagemErroQR = string.Empty;
    private bool isBuscandoProduto = false;

    private int tipoVendaSelecionado = 0;
    private FormaPagamentoEnum metodoPagamentoSelecionado;

    private decimal valorRecebido;
    private string valorRecebidoFormatado = "0,00";
    private string valorRecebidoFormatadoFiado = "0,00";
    private decimal troco = 0;

    private string buscaClienteInput = string.Empty;
    private List<ClienteDTO> clientesEncontrados = new();
    private ClienteDTO? clienteSelecionado = null;

    private string qrCodeDataUrl = string.Empty;
    private Guid documentoGuidAtual = Guid.Empty;
    private bool isGerandoQRCode = false;
    private bool isValidando = false;
    private int vendaIdAtual = 0;

    private System.Timers.Timer? debounceTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || etapaAtual == 1)
            await FocarInput();
    }

    private async Task FocarInput()
    {
        try 
        { 
            if (etapaAtual == 1)
                await inputBuscaProduto.FocusAsync(); 
        } 
        catch { }
    }

    private async Task FocarFinalDinheiro()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "setTimeout(function(){ var el = document.activeElement; if(el && el.tagName==='INPUT'){ el.setSelectionRange(el.value.length, el.value.length); } }, 0)");
        }
        catch { }
    }

    private async Task FocarFinalFiado()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "setTimeout(function(){ var el = document.activeElement; if(el && el.tagName==='INPUT'){ el.setSelectionRange(el.value.length, el.value.length); } }, 0)");
        }
        catch { }
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            debounceTimer?.Stop();
            _ = BuscarEAdicionarProduto();
            return;
        }
        debounceTimer?.Stop();
        debounceTimer = new System.Timers.Timer(500);
        debounceTimer.Elapsed += async (s, ev) =>
        {
            debounceTimer!.Stop();
            await InvokeAsync(BuscarEAdicionarProduto);
        };
        debounceTimer.Start();
    }

    private async Task BuscarEAdicionarProduto()
    {
        if (string.IsNullOrWhiteSpace(codigoBarrasInput) || isBuscandoProduto) return;

        isBuscandoProduto = true;
        mensagemErro = string.Empty;
        StateHasChanged();

        var produto = await VendaService.GetProdutoPorCodigoBarrasAsync(codigoBarrasInput);

        if (produto != null)
        {
            var itemExistente = carrinho.FirstOrDefault(x => x.ProdutoID == produto.ProdutoID);
            if (itemExistente != null)
                itemExistente.Quantidade++;
            else
                carrinho.Add(new ItemVendaDTO
                {
                    ProdutoID     = produto.ProdutoID,
                    NomeProduto   = produto.Nome,
                    PrecoUnitario = produto.PrecoVenda,
                    UnidadeMedida = produto.UnidadeMedida,
                    ComercioId    = Session.CurrentCommerceId != null ? int.Parse(Session.CurrentCommerceId) : 0,
                    Quantidade    = 1
                });

            AtualizarTotalVenda();
            codigoBarrasInput = string.Empty;
        }
        else
        {
            mensagemErro = "Produto não encontrado";
            codigoBarrasInput = string.Empty;
        }

        isBuscandoProduto = false;
        StateHasChanged();
        await FocarInput();
    }

    private void IncrementarQuantidade(int produtoId)
    {
        var item = carrinho.FirstOrDefault(x => x.ProdutoID == produtoId);
        if (item != null) { item.Quantidade++; AtualizarTotalVenda(); }
    }

    private void DecrementarQuantidade(int produtoId)
    {
        var item = carrinho.FirstOrDefault(x => x.ProdutoID == produtoId);
        if (item != null && item.Quantidade > 1) { item.Quantidade--; AtualizarTotalVenda(); }
    }

    private void RemoverItem(int produtoId)
    {
        carrinho.RemoveAll(x => x.ProdutoID == produtoId);
        AtualizarTotalVenda();
        _ = FocarInput();
    }

    private void AtualizarTotalVenda() => totalVenda = carrinho.Sum(x => x.Subtotal);

    private void AtualizarQuantidadeDigitada(int produtoId, object novoValor)
    {
        if (int.TryParse(novoValor?.ToString(), out int qtd) && qtd > 0)
        {
            var item = carrinho.FirstOrDefault(x => x.ProdutoID == produtoId);
            if (item != null) { item.Quantidade = qtd; AtualizarTotalVenda(); StateHasChanged(); }
        }
    }

    private void AvancarParaTipoVenda()
    {
        tipoVendaSelecionado   = 0;
        clienteSelecionado     = null;
        buscaClienteInput      = string.Empty;
        clientesEncontrados.Clear();
        mensagemErro           = string.Empty;
        etapaAtual             = 2;
    }

    private void AvancarParaMetodoPagamento()
    {
        metodoPagamentoSelecionado = 0;
        valorRecebido                 = 0;
        valorRecebidoFormatado        = "0,00";
        valorRecebidoFormatadoFiado   = "0,00";
        troco                         = 0;
        mensagemErro                  = string.Empty;
        etapaAtual                    = 3;
    }

    private void VoltarParaCarrinho()
    {
        tipoVendaSelecionado        = 0;
        metodoPagamentoSelecionado  = 0;
        mensagemErro                = string.Empty;
        etapaAtual                  = 1;
    }

    private void VoltarParaTipoVenda()
    {
        metodoPagamentoSelecionado    = 0;
        valorRecebido                 = 0;
        valorRecebidoFormatado        = "0,00";
        valorRecebidoFormatadoFiado   = "0,00";
        troco                         = 0;
        mensagemErro                  = string.Empty;
        etapaAtual                    = 2;
    }

    private void SelecionarTipoVenda(int tipo)
    {
        tipoVendaSelecionado = tipoVendaSelecionado == tipo ? 0 : tipo;
        if (tipoVendaSelecionado == 1)
        {
            clienteSelecionado = null;
            buscaClienteInput  = string.Empty;
            clientesEncontrados.Clear();
        }
        mensagemErro = string.Empty;
    }

    private void SelecionarMetodoPagamento(FormaPagamentoEnum metodo)
    {
        metodoPagamentoSelecionado  = metodoPagamentoSelecionado == metodo ? 0 : metodo;
        valorRecebido               = 0;
        valorRecebidoFormatado      = "0,00";
        valorRecebidoFormatadoFiado = "0,00";
        troco                       = 0;
        mensagemErro                = string.Empty;
    }

    private bool PodeAvancarDoTipoVenda()
    {
        if (tipoVendaSelecionado == 1) return true;
        if (tipoVendaSelecionado == 2) return clienteSelecionado != null;
        return false;
    }

    private bool PodeProsseguir()
    {
        if (metodoPagamentoSelecionado == 0) return false;

        bool normal = tipoVendaSelecionado == 1;
        bool fiado  = tipoVendaSelecionado == 2;

        if (normal)
        {
            if (metodoPagamentoSelecionado == FormaPagamentoEnum.Dinheiro) return valorRecebido >= totalVenda;
            return true;
        }

        if (fiado)
        {
            return valorRecebido < totalVenda;
        }

        return false;
    }

    private async Task ConfirmarPagamento()
    {
        mensagemErro = string.Empty;

        decimal valorPagamento = tipoVendaSelecionado == 1 ? totalVenda : valorRecebido;

        var vendaRequest = new VendaRequestDTO
        {
            ComercioID  = Session.CurrentCommerceId != null ? int.Parse(Session.CurrentCommerceId) : 0,
            UsuarioID   = Session.CurrentUser?.Id ?? 0,
            ClienteID   = clienteSelecionado?.ClienteID ?? 0,
            TipoVenda   = tipoVendaSelecionado,
            ItensVenda  = carrinho,
            Pagamentos  = new List<PagamentoDTO>
            {
                new PagamentoDTO
                {
                    FormaPagamento = metodoPagamentoSelecionado,
                    Valor          = valorPagamento
                }
            }
        };

        var vendaResponse = await VendaService.RealizarVendaAsync(vendaRequest);

        if (vendaResponse != null)
        {
            vendaIdAtual = vendaResponse.VendaID;
            documentoGuidAtual = vendaResponse.DocumentoGuid.FirstOrDefault();

            if (tipoVendaSelecionado == 2)
            {
                await GerarQRCode(vendaResponse.DocumentoGuid.FirstOrDefault());
                etapaAtual = 4;
            }
            else
            {
                await FinalizarVendaSemAssinatura();
            }
        }
        else
        {
            mensagemErro = "Erro ao processar a venda. Tente novamente.";
        }
    }

    private async Task FinalizarVendaSemAssinatura()
    {
        totalVendaConcluida = totalVenda;
        LimparDadosVenda();
        etapaAtual   = 5;
        mensagemErro = string.Empty;
    }

    private async Task GerarQRCode(Guid documentoGuid)
    {
        isGerandoQRCode = true;
        mensagemErroQR = string.Empty;
        
        string urlSignaturePage = "https://seudominio.com/urlSignaturePage"; 
        string linkFinal = $"{urlSignaturePage}/documento/{documentoGuid}";
        
        qrCodeDataUrl = GerarQRCodeDataUrl(linkFinal);
        
        isGerandoQRCode = false;
        await Task.CompletedTask;
    }

    private string GerarQRCodeDataUrl(string link)
    {
        try
        {
            var qrGenerator = new QRCoder.QRCodeGenerator();
            var qrCodeData  = qrGenerator.CreateQrCode(link, QRCoder.QRCodeGenerator.ECCLevel.Q);
            var qrCode      = new QRCoder.PngByteQRCode(qrCodeData);
            var qrCodeImage = qrCode.GetGraphic(20);
            return "data:image/png;base64," + Convert.ToBase64String(qrCodeImage);
        }
        catch { return string.Empty; }
    }

    private async Task ValidarEEncerrarVenda()
    {
        isValidando = true;
        mensagemErroQR = string.Empty;
        StateHasChanged();

        var isAssinado = await VendaService.VerificarDocumentoAssinadoAsync(documentoGuidAtual);

        if (isAssinado)
        {
            totalVendaConcluida = totalVenda;
            LimparDadosVenda();
            etapaAtual   = 5;
            mensagemErro = string.Empty;
        }
        else
        {
            mensagemErroQR = "Assinatura não finalizada.";
        }

        isValidando = false;
        StateHasChanged();
    }

    private async Task DesistirDaVenda()
    {
        isValidando = true;
        mensagemErroQR = string.Empty;
        StateHasChanged();

        var sucesso = await VendaService.DesistirVendaAsync(vendaIdAtual);

        if (sucesso)
        {
            LimparDadosVenda();
            etapaAtual   = 1;
            mensagemErro = string.Empty;
            await FocarInput();
        }
        else
        {
            mensagemErroQR = "Erro ao desistir da venda. Tente novamente.";
        }

        isValidando = false;
        StateHasChanged();
    }

    private async Task BuscarClientes()
    {
        if (buscaClienteInput.Length >= 3)
            clientesEncontrados = await VendaService.BuscarClientesAsync(buscaClienteInput);
        else
            clientesEncontrados.Clear();
    }

    private void SelecionarCliente(ClienteDTO cliente)
    {
        clienteSelecionado = cliente;
        buscaClienteInput = cliente.Nome;
        clientesEncontrados.Clear();
    }

    private void FormatarInputDinheiro(ChangeEventArgs e)
    {
        valorRecebidoFormatado = FormatarInputEmTempoReal(e.Value?.ToString() ?? string.Empty);
        valorRecebido          = ParseDecimal(valorRecebidoFormatado);
        CalcularTroco();
        StateHasChanged();
    }

    private void FormatarInputFiado(ChangeEventArgs e)
    {
        valorRecebidoFormatadoFiado = FormatarInputEmTempoReal(e.Value?.ToString() ?? string.Empty);
        valorRecebido               = ParseDecimal(valorRecebidoFormatadoFiado);
        StateHasChanged();
    }

    private void CalcularTroco()
    {
        troco = valorRecebido - totalVenda;
        if (troco < 0) troco = 0;
    }

    private string FormatarInputEmTempoReal(string input)
    {
        string digits = System.Text.RegularExpressions.Regex.Replace(input, @"[^\d]", "");
        digits = digits.PadLeft(1, '0');
        if (digits.Length > 10) digits = digits.Substring(0, 10);

        if (digits.Length <= 2)
            return "0," + digits.PadLeft(2, '0');

        int    pos     = digits.Length - 2;
        string intPart = digits.Substring(0, pos);
        string decPart = digits.Substring(pos);
        intPart = int.Parse(intPart)
                     .ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))
                     .Replace(".", "");
        return intPart + "," + decPart;
    }

    private decimal ParseDecimal(string valor)
    {
        if (string.IsNullOrWhiteSpace(valor)) return 0;
        var v = valor.Replace(",", ".");
        return decimal.TryParse(v, System.Globalization.NumberStyles.Any,
                                System.Globalization.CultureInfo.InvariantCulture, out decimal r) ? r : 0;
    }

    private string FormatarNumero(decimal valor) =>
        valor.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));

    private async Task RealizarNovaVenda()
    {
        etapaAtual = 1;
        await FocarInput();
    }

