@page "/"
@page "/login"
@inject IAuthService AuthService
@inject UserSession Session
@inject SessionService SessionService
@inject NavigationManager Navigation

<PageTitle>Ninx ERP — Login</PageTitle>

<div class="login-root-v6">
    <div class="bg-grid"></div>
    <div class="bg-glow"></div>

    @if (isLoading)
    {
        <div class="loading-overlay">
            <div class="spinner-border text-info" role="status">
                <span class="visually-hidden">Autenticando...</span>
            </div>
        </div>
    }

    @if (showCommerceSelection && comerciosDisponiveis != null && comerciosDisponiveis.Count > 0)
    {
        <div class="modal-overlay">
            <div class="modal-card">
                <header class="modal-header">
                    <h2 class="text-white">Selecionar Comércio</h2>
                </header>
                <div class="commerce-list mt-3">
                    @foreach (var comercio in comerciosDisponiveis)
                    {
                        <button class="commerce-option"
                                @onclick="() => SelectComercio(comercio.ComercioID)">
                            <span>@comercio.Nome</span>
                            <i class="bi bi-chevron-right icon-indicator"></i>
                        </button>
                    }
                </div>
                <footer class="modal-footer mt-3">
                    <button class="btn-cancel" @onclick="CancelCommerceSelection">Cancelar</button>
                </footer>
            </div>
        </div>
    }

    <div class="login-card @(isAnimating ? "fade-in" : "")">
        <div class="card-body">
            <header class="brand-header">
                <div class="logo-wrapper">
                    <img src="images/nina_logo_clean.png" alt="Logo" class="brand-logo" />
                </div>
                <h1 class="brand-title">Ninx</h1>
                <div class="accent-line"></div>
            </header>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @errorMessage
                    <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                </div>
            }

            <EditForm Model="@loginModel" OnValidSubmit="OnSubmit" class="auth-form">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="email" class="form-label">E-mail</label>
                    <InputText id="email" @bind-value="loginModel.Email" 
                              placeholder="seu@email.com" 
                              class="form-control" />
                    <ValidationMessage For="@(() => loginModel.Email)" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Senha</label>
                    <div class="input-group">
                        <InputText id="password" @bind-value="loginModel.Password" 
                                  type="@(showPass ? "text" : "password")" 
                                  placeholder="••••••••" 
                                  class="form-control" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="() => showPass = !showPass" title="Mostrar/ocultar">
                            <i class="bi @(showPass ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => loginModel.Password)" class="text-danger small" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@isLoading">
                    Entrar
                </button>
            </EditForm>

            <footer class="card-footer">
                <a href="/forgot-password" class="footer-link">Esqueci minha senha</a>
            </footer>
        </div>
    </div>
</div>

@code {
    private LoginViewModel loginModel = new();
    private bool isLoading;
    private bool isAnimating;
    private bool showPass;
    private bool showCommerceSelection;
    private List<ComercioOption>? comerciosDisponiveis;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (Session != null && Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/mainpage", true);
        }
        isAnimating = true;
    }

    private async Task OnSubmit()
    {
        errorMessage = null;
        isLoading = true;

        var result = await AuthService.AuthenticateAsync(loginModel.Email, loginModel.Password);

        if (result.Success)
        {
            // Forçar o reload para garantir que o estado do Singleton seja reconhecido em todas as camadas
            Navigation.NavigateTo("/mainpage", true);
        }
        else if (result.Response?.Comercios != null && result.Response.Comercios.Count > 0)
        {
            comerciosDisponiveis = result.Response.Comercios;
            showCommerceSelection = true;
            isLoading = false;
        }
        else
        {
            errorMessage = result.Message;
            isLoading = false;
        }
    }

    private async Task SelectComercio(int comercioId)
    {
        isLoading = true;
        showCommerceSelection = false;

        var result = await AuthService.AuthenticateAsync(loginModel.Email, loginModel.Password, comercioId);

        if (result.Success)
        {
            Navigation.NavigateTo("/mainpage", true);
        }
        else
        {
            errorMessage = result.Message;
            isLoading = false;
        }
    }

    private void CancelCommerceSelection()
    {
        showCommerceSelection = false;
        comerciosDisponiveis = null;
        isLoading = false;
    }

    public class LoginViewModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "O e-mail é obrigatório.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Formato inválido.")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "A senha é obrigatória.")]
        public string Password { get; set; } = string.Empty;
    }
}
