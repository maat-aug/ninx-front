@page "/mainpage"
@using NinxERP.Domain.Entities
@inject UserSession Session
@inject NavigationManager Navigation

<PageTitle>Início — Ninx ERP</PageTitle>

@if (Session == null || !Session.IsAuthenticated)
{
    <div class="auth-guard">
        <p>Acesso negado. Redirecionando...</p>
    </div>
}
else
{
    <div class="mainpage-root">
        <div class="bg-grid-dash"></div>
        <div class="bg-glow-dash"></div>

        <nav class="top-nav">
            <div class="brand-section">
                <img src="images/nina_logo_clean.png" alt="Nina" class="brand-logo-small" />
                <div class="brand-info">
                    <span class="brand-name-dash">Ninx</span>
                </div>
            </div>
            
            <div class="user-controls">
                <div class="welcome-stack">
                    <span class="welcome-text">Olá, <strong>@Session.CurrentUser?.Name</strong></span>
                    <span class="commerce-name user-commerce-name">@Session.CurrentCommerce?.Name</span>
                </div>
                <button class="menu-trigger" @onclick="ToggleMenu" aria-label="Abrir menu">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
            </div>
        </nav>

        @if (isMenuOpen)
        {
            <div class="menu-overlay" @onclick="ToggleMenu">
                <div class="side-menu" @onclick:stopPropagation>
                    <header class="menu-header">
                        <h3>Menu de Ações</h3>
                        <button class="close-btn" @onclick="ToggleMenu" aria-label="Fechar menu">✕</button>
                    </header>
                    <div class="menu-items">
                        <button class="menu-item" @onclick="OpenCommerceModal">
                            <div class="item-icon">🏪</div>
                            <div class="item-text">
                                <span>Trocar Comércio</span>
                                <small>Selecionar outra unidade</small>
                            </div>
                        </button>

                        <button class="menu-item logout-item" @onclick="Logout">
                            <div class="item-icon">👤</div>
                            <div class="item-text">
                                <span>Trocar Usuário</span>
                                <small>Sair desta conta</small>
                            </div>
                        </button>

                        @if (Session.IsAdmin)
                        {
                            <div class="menu-divider"></div>
                            <button class="menu-item admin-item" @onclick='() => NavigateTo("admin")'>
                                <div class="item-icon">🛡️</div>
                                <div class="item-text">
                                    <span>Painel Admin</span>
                                    <small>Gestão do sistema</small>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        @if (isCommerceModalOpen)
        {
            <div class="modal-overlay">
                <div class="modal-card">
                    <header class="modal-header">
                        <h2>Selecionar Unidade</h2>
                    </header>
                    <div class="commerce-list">
                        @if (Session.AvailableCommerces != null)
                        {
                            @foreach (var commerce in Session.AvailableCommerces)
                            {
                                <button class="commerce-option @(Session.CurrentCommerce?.Id == commerce.Id ? "active" : "")" 
                                        @onclick="() => SelectCommerce(commerce.Id)">
                                    <span class="opt-name">@commerce.Name</span>
                                    @if (Session.CurrentCommerce?.Id == commerce.Id)
                                    {
                                        <span class="opt-badge">Atual</span>
                                    }
                                </button>
                            }
                        }
                    </div>
                    <footer class="modal-footer">
                        <button class="btn-cancel" @onclick="CloseCommerceModal">Cancelar</button>
                    </footer>
                </div>
            </div>
        }

        <main class="main-content">
            <div class="action-grid">
                <!-- Posição 1 -->
                <div class="action-card" @onclick='() => NavigateTo("produtos")'>
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                    </div>
                    <h2 class="card-title">Produtos e Estoque</h2>
                    <p class="card-desc">Cadastrar itens e controlar quantidades.</p>
                </div>

                <!-- Posição 2 - SEMPRE REALIZAR VENDA -->
                <div class="action-card card-primary" @onclick='() => NavigateTo("venda")'>
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
                    </div>
                    <h2 class="card-title">Realizar Venda</h2>
                    <p class="card-desc">Clique aqui para abrir o caixa e vender agora.</p>
                </div>

                <!-- Posição 3 -->
                <div class="action-card" @onclick='() => NavigateTo("clientes")'>
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    </div>
                    <h2 class="card-title">Meus Clientes</h2>
                    <p class="card-desc">Ver lista de contatos e cadastrar novos.</p>
                </div>

                @if (Session.IsManager)
                {
                    <!-- Posição 4 -->
                    <div class="action-card" @onclick='() => NavigateTo("relatorios")'>
                        <div class="card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                        </div>
                        <h2 class="card-title">Relatórios e Gráficos</h2>
                        <p class="card-desc">Acompanhar o crescimento das suas vendas.</p>
                    </div>

                    <!-- Posição 5 -->
                    <div class="action-card" @onclick='() => NavigateTo("assinatura")'>
                        <div class="card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        </div>
                        <h2 class="card-title">Minha Assinatura</h2>
                        <p class="card-desc">Ver status do seu plano e pagamentos.</p>
                    </div>

                    <!-- Posição 6 -->
                    <div class="action-card" @onclick='() => NavigateTo("gestao")'>
                        <div class="card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                        </div>
                        <h2 class="card-title">Gestão</h2>
                        <p class="card-desc">Controlar usuários, categorias, produtos e comércio.</p>
                    </div>
                }
            </div>
        </main>
    </div>
}

@code {
    private bool isMenuOpen;
    private bool isCommerceModalOpen;

    protected override void OnInitialized()
    {
        if (Session == null || !Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }
    }

    private void ToggleMenu() => isMenuOpen = !isMenuOpen;
    
    private void OpenCommerceModal()
    {
        isMenuOpen = false;
        isCommerceModalOpen = true;
    }

    private void CloseCommerceModal() => isCommerceModalOpen = false;

    private void SelectCommerce(string id)
    {
        if (Session != null)
        {
            Session.ChangeCommerce(id);
        }
        CloseCommerceModal();
    }

    private void NavigateTo(string route)
    {
        isMenuOpen = false;
        Navigation.NavigateTo($"/mainpage/{route}");
    }

    private void Logout()
    {
        if (Session != null)
        {
            Session.End();
        }
        Navigation.NavigateTo("/login");
    }
}
