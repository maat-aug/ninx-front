@page "/forgot-password"
@using NinxERP.Domain.Entities
@inject NavigationManager Navigation

<PageTitle>Recuperar Senha — Ninx ERP</PageTitle>

<div class="login-root-v6">
    <div class="bg-grid"></div>
    <div class="bg-glow"></div>

    @if (isLoading)
    {
        <div class="loading-overlay">
            <div class="spinner-border text-info" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }

    <div class="login-card @(isAnimating ? "fade-in" : "")">
        <div class="card-body">
            <header class="brand-header">
                <button class="back-button" @onclick="GoBack" title="Voltar">
                    <i class="bi bi-arrow-left"></i>
                </button>
                <div class="logo-wrapper">
                    <img src="images/nina_logo_clean.png" alt="Logo" class="brand-logo" />
                </div>
                <h1 class="brand-title">Recuperar Senha</h1>
                <div class="accent-line"></div>
            </header>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @errorMessage
                    <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                </div>
            }

            @if (currentStep == PasswordRecoveryStep.Email)
            {
                <div class="recovery-step">
                    
                    <div class="mb-3">
                        <label for="email" class="form-label">E-mail</label>
                        <input type="email" id="email" @bind="recoveryEmail" placeholder="seu@email.com" class="form-control" />
                    </div>

                    <button type="button" class="btn btn-primary w-100" @onclick="SendRecoveryCode" disabled="@isLoading">
                        Enviar Código
                    </button>
                </div>
            }
            else if (currentStep == PasswordRecoveryStep.Code)
            {
                <div class="recovery-step">
                    <p class="step-description">Digite o código de 6 dígitos enviado para <strong>@recoveryEmail</strong></p>
                    
                    <div class="code-input-group">
                        @for (int i = 0; i < 6; i++)
                        {
                            int index = i;
                            <input 
                                type="text" 
                                class="code-slot" 
                                maxlength="1" 
                                @bind="codeDigits[index]"
                                @onkeydown="(KeyboardEventArgs e) => HandleCodeInput(e, index)"
                                placeholder=""
                                inputmode="numeric"
                            />
                        }
                    </div>

                    <button type="button" class="btn btn-primary w-100" @onclick="ValidateCode" disabled="@isLoading">
                        Validar Código
                    </button>
                </div>
            }
            else if (currentStep == PasswordRecoveryStep.NewPassword)
            {
                <div class="recovery-step">
                    <p class="step-description">Digite sua nova senha.</p>
                    
                    <div class="mb-3">
                        <label for="newpass" class="form-label">Nova Senha</label>
                        <div class="input-group">
                            <input type="@(showNewPass ? "text" : "password")" id="newpass" @bind="newPassword" placeholder="••••••••" class="form-control" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => showNewPass = !showNewPass" title="Mostrar/ocultar">
                                <i class="bi @(showNewPass ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="confirmpass" class="form-label">Confirmar Senha</label>
                        <div class="input-group">
                            <input type="@(showConfirmPass ? "text" : "password")" id="confirmpass" @bind="confirmPassword" placeholder="••••••••" class="form-control" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => showConfirmPass = !showConfirmPass" title="Mostrar/ocultar">
                                <i class="bi @(showConfirmPass ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary w-100" @onclick="ResetPassword" disabled="@isLoading">
                        Redefinir Senha
                    </button>
                </div>
            }

            <footer class="card-footer">
                Ninx v1.0.0
            </footer>
        </div>
    </div>
</div>

@code {
    private enum PasswordRecoveryStep { Email, Code, NewPassword }
    
    private PasswordRecoveryStep currentStep = PasswordRecoveryStep.Email;
    private string recoveryEmail = string.Empty;
    private string[] codeDigits = new string[6] { "", "", "", "", "", "" };
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private bool showNewPass;
    private bool showConfirmPass;
    private bool isLoading;
    private bool isAnimating;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        isAnimating = true;
    }

    private async Task SendRecoveryCode()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(recoveryEmail))
        {
            errorMessage = "Digite um e-mail válido.";
            return;
        }

        isLoading = true;
        await Task.Delay(1500);

        if (recoveryEmail.Contains("@"))
        {
            currentStep = PasswordRecoveryStep.Code;
            isLoading = false;
        }
        else
        {
            errorMessage = "E-mail não encontrado no sistema.";
            isLoading = false;
        }
    }

    private async Task ValidateCode()
    {
        errorMessage = null;
        string fullCode = string.Join("", codeDigits);

        if (string.IsNullOrWhiteSpace(fullCode) || fullCode.Length != 6)
        {
            errorMessage = "Digite todos os 6 dígitos.";
            return;
        }

        isLoading = true;
        await Task.Delay(1500);

        if (fullCode == "123456")
        {
            currentStep = PasswordRecoveryStep.NewPassword;
            isLoading = false;
        }
        else
        {
            errorMessage = "Código inválido. Tente novamente.";
            isLoading = false;
        }
    }

    private async Task ResetPassword()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newPassword) || newPassword.Length < 6)
        {
            errorMessage = "A senha deve ter pelo menos 6 caracteres.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "As senhas não coincidem.";
            return;
        }

        isLoading = true;
        await Task.Delay(1500);

        Navigation.NavigateTo("/login?reset=success");
    }

    private void HandleCodeInput(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Backspace")
        {
            codeDigits[index] = "";
            if (index > 0)
            {
                // Foco no campo anterior
            }
        }
        else if (char.IsDigit(e.Key[0]))
        {
            codeDigits[index] = e.Key;
            if (index < 5)
            {
                // Foco no próximo campo
            }
        }
    }

    private void GoBack()
    {
        if (currentStep == PasswordRecoveryStep.Email)
        {
            Navigation.NavigateTo("/login");
        }
        else if (currentStep == PasswordRecoveryStep.Code)
        {
            currentStep = PasswordRecoveryStep.Email;
            codeDigits = new string[6] { "", "", "", "", "", "" };
            errorMessage = null;
        }
        else if (currentStep == PasswordRecoveryStep.NewPassword)
        {
            currentStep = PasswordRecoveryStep.Code;
            newPassword = string.Empty;
            confirmPassword = string.Empty;
            errorMessage = null;
        }
    }
}
